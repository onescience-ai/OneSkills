{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/onescience-ai/oneskills/catalog/schema.json",
  "title": "OneSkills Catalog Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "package",
    "version",
    "skills_version",
    "generated_at",
    "skills"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "package": {
      "type": "string",
      "const": "oneskills"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "skills_version": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "layer",
          "tags",
          "location",
          "source"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^skill:[a-z0-9][a-z0-9-]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "layer": {
            "type": "string",
            "enum": [
              "workflow",
              "role",
              "routing",
              "codegen",
              "runtime",
              "installer"
            ]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "location": {
            "type": "string",
            "pattern": "^skills/[a-z0-9][a-z0-9-]*/SKILL\\.md$"
          },
          "source": {
            "type": "string",
            "enum": [
              "official"
            ]
          }
        }
      }
    }
  }
}
