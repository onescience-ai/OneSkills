        }
      }
    },
    "precheck": {
      "installer_backend": "dcu_remote_install",
      "workspace_bootstrap_profile": "onescience_gitee_workspace",
      "precheck_outcome": "ready_to_install",
      "installer_scope": "user_space_only",
      "blocking_reason": "none",
      "confirmation_required": false,
      "platform_action_required": false,
      "install_command_plan": {
