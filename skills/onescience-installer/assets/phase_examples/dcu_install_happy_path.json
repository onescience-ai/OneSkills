    "install": {
      "install_state": "install_commands_completed",
      "install_command": "set -o pipefail && (test -f ~/.bashrc && source ~/.bashrc || true) && module load sghpcdas/25.6 && module load sghpc-mpi-gcc/26.3 && (conda env list | grep -w onescience311 >/dev/null 2>&1 || conda create -n onescience311 python=3.11 -y || (source /work2/share/sghpc_sdk/Linux_x86_64/25.6/das/conda/bin/activate && conda create -n onescience311 python=3.11 -y)) && conda activate onescience311 && ([ -d ~/onescience/.git ] || git clone https://gitee.com/onescience-ai/onescience.git ~/onescience) && cd ~/onescience && git fetch --all && git checkout main && git pull --ff-only && bash install.sh earth",
      "install_target": {
        "host": "login-kunshan",
        "backend_id": "slurm_dcu"
      },
      "workspace_state": "ready",
      "install_artifacts": [
        "conda_env:onescience311",
        "repo:onescience@main"
      ],
      "evidence": {
