          "command_exit_code": 0
        }
      }
    },
    "verify": {
      "verify_command": "set -o pipefail && (test -f ~/.bashrc && source ~/.bashrc || true) && module load sghpcdas/25.6 && module load sghpc-mpi-gcc/26.3 && conda activate onescience311 && pip list | grep torch && pip list | grep onescience",
      "install_state": "install_succeeded_and_verified",
      "verify_state": "verified",
      "installed_env_summary": {
        "conda_env": "onescience311",
        "python": "3.11",
        "framework_stack": "rocm_dcu_torch_ready",
        "domain_selector": "earth"
