{
  "runtime": {
    "mode": "slurm",
    "backend_id": "slurm_gpu_multinode_torchrun",
    "execution_profile": {
      "execution_mode": "remote_slurm",
      "access_mode": "ssh",
      "runtime_profile_ref": "remote_slurm_gpu_multinode_torchrun",
      "install_profile_ref": "gpu_remote_install_profile"
    },
    "target": {
      "scheduler_type": "slurm",
      "platform_type": "cluster",
      "cpu_arch": "x86_64",
      "cpu_vendor": "intel",
      "accelerator_kind": "gpu",
      "accelerator_vendor": "nvidia",
      "node_scope": "multi_node"
    },
    "environment": {
      "cpu": {
        "arch": "x86_64",
        "vendor": "intel"
      },
      "accelerator_defaults": {
        "kind": "gpu",
        "vendor": "nvidia",
        "visibility_env": "CUDA_VISIBLE_DEVICES",
        "distributed_backend": "nccl",
        "launch_mode": "torchrun",
        "distributed_mode": "multi_node"
      }
    },
    "cluster": {
      "partition": "gpu_normal",
      "nodes": 2,
      "gpus_per_node": 4,
      "cpus_per_task": 8,
      "memory": "128GB",
      "time_limit": "04:00:00",
      "gpu_type": "gpu",
      "ntasks_per_node": 4
    },
    "modules": [
      "cuda/12.1",
      "gcc/11.2"
    ],
    "conda": {
      "enabled": true,
      "env_name": "onescience311",
      "activate_script": "source ~/.bashrc && conda activate onescience311"
    },
    "resources": {
      "gpu_type": "gpu",
      "cpu_memory_ratio": 8,
      "disk_space": "100GB"
    },
    "script": {
      "path": "slurm_multinode_submit.sh",
      "generate": true,
      "template": "slurm_gpu_multinode_torchrun",
      "job_name": "weather_forecast_multinode_gpu",
      "code_path": "run_multinode_forecast.py",
      "env_vars": {
        "ONESCIENCE_DATASETS_DIR": "/mnt/datasets/onedatasets/",
        "ONESCIENCE_MODELS_DIR": "/mnt/models/onemodels/",
        "MASTER_PORT": "29500"
      },
      "work_dir": "."
    }
  }
}
