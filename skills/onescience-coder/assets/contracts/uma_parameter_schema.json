{
  "schema_version": "1.0",
  "model": "uma",
  "purpose": "Machine-readable parameter table for OneScience UMA Hydra override generation and validation.",
  "task_types": [
    "checkpoint_inference",
    "finetune_energy",
    "finetune_ef",
    "finetune_efs",
    "relax_or_md",
    "batch_inference",
    "molecule_charge_spin",
    "crystal_or_adsorbate_pbc",
    "moe_advanced"
  ],
  "task_target_map": {
    "finetune_energy": ["energy"],
    "finetune_ef": ["energy", "forces"],
    "finetune_efs": ["energy", "forces", "stress"]
  },
  "required_by_task": {
    "checkpoint_inference": [
      "checkpoint_location",
      "task_name",
      "device"
    ],
    "finetune_energy": [
      "runner.train_eval_unit.model.checkpoint_location",
      "data.dataset_name",
      "data.elem_refs",
      "data.normalizer_rmsd",
      "data.train_dataset",
      "data.val_dataset",
      "data.heads",
      "data.tasks_list",
      "optim.lr"
    ],
    "finetune_ef": [
      "runner.train_eval_unit.model.checkpoint_location",
      "data.dataset_name",
      "data.elem_refs",
      "data.normalizer_rmsd",
      "data.train_dataset",
      "data.val_dataset",
      "data.heads",
      "data.tasks_list",
      "runner.train_eval_unit.model.overrides.backbone.regress_stress",
      "optim.lr"
    ],
    "finetune_efs": [
      "runner.train_eval_unit.model.checkpoint_location",
      "data.dataset_name",
      "data.elem_refs",
      "data.normalizer_rmsd",
      "data.train_dataset",
      "data.val_dataset",
      "data.heads",
      "data.tasks_list",
      "runner.train_eval_unit.model.overrides.backbone.regress_stress",
      "optim.lr"
    ],
    "relax_or_md": [
      "checkpoint_location",
      "task_name",
      "device",
      "structure_file"
    ],
    "batch_inference": [
      "checkpoint_location",
      "task_name",
      "device",
      "input_path"
    ],
    "molecule_charge_spin": [
      "checkpoint_location",
      "task_name",
      "device",
      "r_data_keys"
    ],
    "crystal_or_adsorbate_pbc": [
      "checkpoint_location",
      "task_name",
      "device",
      "pbc"
    ],
    "moe_advanced": [
      "runner.train_eval_unit.model.checkpoint_location",
      "data.dataset_name",
      "data.heads",
      "data.tasks_list"
    ]
  },
  "parameters": [
    {
      "name": "checkpoint_location",
      "type": "path",
      "default": null,
      "required_when": ["checkpoint_inference", "relax_or_md", "batch_inference", "molecule_charge_spin", "crystal_or_adsorbate_pbc"],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/src/onescience/utils/uma/units/mlip_unit/mlip_unit.py",
      "tasks": ["checkpoint_inference", "relax_or_md", "batch_inference", "molecule_charge_spin", "crystal_or_adsorbate_pbc"],
      "auto_generate": true
    },
    {
      "name": "task_name",
      "type": "enum",
      "default": null,
      "required_when": ["checkpoint_inference", "relax_or_md", "batch_inference", "molecule_charge_spin", "crystal_or_adsorbate_pbc"],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/examples/matchem/uma/inference/*.py",
      "tasks": ["checkpoint_inference", "relax_or_md", "batch_inference", "molecule_charge_spin", "crystal_or_adsorbate_pbc"],
      "auto_generate": true,
      "allowed_values": ["oc20", "omat", "omol", "custom"]
    },
    {
      "name": "device",
      "type": "enum",
      "default": "cuda",
      "required_when": ["checkpoint_inference", "relax_or_md", "batch_inference", "molecule_charge_spin", "crystal_or_adsorbate_pbc"],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/examples/matchem/uma/inference/*.py",
      "tasks": ["checkpoint_inference", "relax_or_md", "batch_inference", "molecule_charge_spin", "crystal_or_adsorbate_pbc", "finetune_energy", "finetune_ef", "finetune_efs"],
      "auto_generate": true,
      "allowed_values": ["cuda", "cpu"]
    },
    {
      "name": "data.dataset_name",
      "type": "string",
      "default": null,
      "required_when": ["finetune_energy", "finetune_ef", "finetune_efs", "moe_advanced"],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/examples/matchem/uma/configs/data/*.yaml",
      "tasks": ["finetune_energy", "finetune_ef", "finetune_efs", "moe_advanced"],
      "auto_generate": true
    },
    {
      "name": "data.elem_refs",
      "type": "list_float",
      "default": null,
      "required_when": ["finetune_energy", "finetune_ef", "finetune_efs"],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/examples/matchem/uma/scripts/create_uma_finetune_dataset.py",
      "tasks": ["finetune_energy", "finetune_ef", "finetune_efs"],
      "auto_generate": true
    },
    {
      "name": "data.normalizer_rmsd",
      "type": "float",
      "default": null,
      "required_when": ["finetune_energy", "finetune_ef", "finetune_efs"],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/examples/matchem/uma/scripts/create_uma_finetune_dataset.py",
      "tasks": ["finetune_energy", "finetune_ef", "finetune_efs"],
      "auto_generate": true
    },
    {
      "name": "data.train_dataset",
      "type": "path_or_dict",
      "default": null,
      "required_when": ["finetune_energy", "finetune_ef", "finetune_efs"],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/examples/matchem/uma/configs/data/*.yaml",
      "tasks": ["finetune_energy", "finetune_ef", "finetune_efs"],
      "auto_generate": true
    },
    {
      "name": "data.val_dataset",
      "type": "path_or_dict",
      "default": null,
      "required_when": ["finetune_energy", "finetune_ef", "finetune_efs"],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/examples/matchem/uma/configs/data/*.yaml",
      "tasks": ["finetune_energy", "finetune_ef", "finetune_efs"],
      "auto_generate": true
    },
    {
      "name": "data.heads",
      "type": "dict",
      "default": null,
      "required_when": ["finetune_energy", "finetune_ef", "finetune_efs", "moe_advanced"],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/src/onescience/modules/head/uma_head.py",
      "tasks": ["finetune_energy", "finetune_ef", "finetune_efs", "moe_advanced"],
      "auto_generate": true
    },
    {
      "name": "data.tasks_list",
      "type": "list_dict",
      "default": null,
      "required_when": ["finetune_energy", "finetune_ef", "finetune_efs", "moe_advanced"],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/src/onescience/utils/uma/units/mlip_unit/mlip_unit.py",
      "tasks": ["finetune_energy", "finetune_ef", "finetune_efs", "moe_advanced"],
      "auto_generate": true
    },
    {
      "name": "runner.train_eval_unit.model.checkpoint_location",
      "type": "path",
      "default": null,
      "required_when": ["finetune_energy", "finetune_ef", "finetune_efs", "moe_advanced"],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/src/onescience/utils/uma/units/mlip_unit/mlip_unit.py",
      "tasks": ["finetune_energy", "finetune_ef", "finetune_efs", "moe_advanced"],
      "auto_generate": true
    },
    {
      "name": "runner.train_eval_unit.model.overrides.backbone.regress_stress",
      "type": "bool",
      "default": false,
      "required_when": ["finetune_ef", "finetune_efs"],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/src/onescience/models/UMA/uma_escn_md.py",
      "tasks": ["finetune_ef", "finetune_efs"],
      "auto_generate": true
    },
    {
      "name": "runner.train_eval_unit.model.overrides.backbone.always_use_pbc",
      "type": "bool",
      "default": false,
      "required_when": [],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/src/onescience/models/UMA/uma_escn_md.py",
      "tasks": ["finetune_energy", "finetune_ef", "finetune_efs", "crystal_or_adsorbate_pbc"],
      "auto_generate": true
    },
    {
      "name": "runner.train_eval_unit.model.overrides.backbone.max_neighbors",
      "type": "int",
      "default": 300,
      "required_when": [],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/src/onescience/models/UMA/uma_escn_md.py",
      "tasks": ["finetune_energy", "finetune_ef", "finetune_efs", "crystal_or_adsorbate_pbc"],
      "auto_generate": false
    },
    {
      "name": "runner.train_eval_unit.model.overrides.backbone.jd_path",
      "type": "path",
      "default": null,
      "required_when": [],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/src/onescience/modules/func_utils/uma_path_utils.py",
      "tasks": ["finetune_energy", "finetune_ef", "finetune_efs", "checkpoint_inference"],
      "auto_generate": true
    },
    {
      "name": "optim.lr",
      "type": "float",
      "default": 0.0004,
      "required_when": ["finetune_energy", "finetune_ef", "finetune_efs"],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/examples/matchem/uma/demo/configs/*.yaml",
      "tasks": ["finetune_energy", "finetune_ef", "finetune_efs"],
      "auto_generate": true
    },
    {
      "name": "optim.weight_decay",
      "type": "float",
      "default": 0.001,
      "required_when": [],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/examples/matchem/uma/demo/configs/*.yaml",
      "tasks": ["finetune_energy", "finetune_ef", "finetune_efs"],
      "auto_generate": true
    },
    {
      "name": "trainer.batch_size",
      "type": "int",
      "default": 2,
      "required_when": [],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/examples/matchem/uma/demo/configs/*.yaml",
      "tasks": ["finetune_energy", "finetune_ef", "finetune_efs"],
      "auto_generate": true
    },
    {
      "name": "trainer.max_steps",
      "type": "int",
      "default": null,
      "required_when": [],
      "mutually_exclusive_with": ["trainer.epochs"],
      "source_script": "./onescience/examples/matchem/uma/demo/configs/*.yaml",
      "tasks": ["finetune_energy", "finetune_ef", "finetune_efs"],
      "auto_generate": true
    },
    {
      "name": "trainer.epochs",
      "type": "int",
      "default": 1,
      "required_when": [],
      "mutually_exclusive_with": ["trainer.max_steps"],
      "source_script": "./onescience/examples/matchem/uma/demo/configs/*.yaml",
      "tasks": ["finetune_energy", "finetune_ef", "finetune_efs"],
      "auto_generate": true
    },
    {
      "name": "trainer.evaluate_every_n_steps",
      "type": "int",
      "default": 100,
      "required_when": [],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/examples/matchem/uma/demo/configs/*.yaml",
      "tasks": ["finetune_energy", "finetune_ef", "finetune_efs"],
      "auto_generate": true
    },
    {
      "name": "trainer.checkpoint_every_n_steps",
      "type": "int",
      "default": 1000,
      "required_when": [],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/examples/matchem/uma/demo/configs/*.yaml",
      "tasks": ["finetune_energy", "finetune_ef", "finetune_efs"],
      "auto_generate": true
    },
    {
      "name": "r_data_keys",
      "type": "list_string",
      "default": null,
      "required_when": ["molecule_charge_spin"],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/examples/matchem/uma/inference/*.py",
      "tasks": ["checkpoint_inference", "molecule_charge_spin", "batch_inference"],
      "auto_generate": true
    },
    {
      "name": "molecule_cell_size",
      "type": "float",
      "default": null,
      "required_when": [],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/examples/matchem/uma/inference/*.py",
      "tasks": ["molecule_charge_spin", "checkpoint_inference"],
      "auto_generate": true
    },
    {
      "name": "charge",
      "type": "int",
      "default": 0,
      "required_when": [],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/datapipes/materials/uma_transforms.py",
      "tasks": ["molecule_charge_spin"],
      "auto_generate": false
    },
    {
      "name": "spin",
      "type": "int",
      "default": 0,
      "required_when": [],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/datapipes/materials/uma_transforms.py",
      "tasks": ["molecule_charge_spin"],
      "auto_generate": false
    },
    {
      "name": "pbc",
      "type": "bool_or_list_bool",
      "default": null,
      "required_when": ["crystal_or_adsorbate_pbc"],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/src/onescience/modules/func_utils/uma_graph/compute.py",
      "tasks": ["crystal_or_adsorbate_pbc", "relax_or_md", "batch_inference"],
      "auto_generate": true
    },
    {
      "name": "structure_file",
      "type": "path",
      "default": null,
      "required_when": ["relax_or_md"],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/examples/matchem/uma/inference/*.py",
      "tasks": ["relax_or_md"],
      "auto_generate": true
    },
    {
      "name": "input_path",
      "type": "path",
      "default": null,
      "required_when": ["batch_inference"],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/examples/matchem/uma/inference/*.py",
      "tasks": ["batch_inference"],
      "auto_generate": true
    },
    {
      "name": "moe.enabled",
      "type": "bool",
      "default": false,
      "required_when": ["moe_advanced"],
      "mutually_exclusive_with": [],
      "source_script": "./onescience/src/onescience/models/UMA/uma_escn_moe.py",
      "tasks": ["moe_advanced"],
      "auto_generate": false
    }
  ],
  "validation_rules": [
    {
      "id": "uma_stats_same_source",
      "severity": "error",
      "description": "dataset_name, elem_refs, normalizer_rmsd, head and tasks_list must be derived from the same dataset/task context."
    },
    {
      "id": "uma_efs_requires_stress",
      "severity": "error",
      "description": "regress_stress=true requires stress labels, stress tasks and stress-compatible output keys."
    },
    {
      "id": "uma_ef_no_stress",
      "severity": "error",
      "description": "EF tasks must keep regress_stress=false unless the task is explicitly EFS."
    },
    {
      "id": "uma_omol_requires_charge_spin",
      "severity": "error",
      "description": "OMOL or molecule charge/spin inference requires r_data_keys to include spin and charge or an explicit data preparation policy."
    }
  ]
}
